{
    /////////////
    // General //
    /////////////

    "disable_ai": false,
    "project_panel": {
        "dock": "left"
    },
    "outline_panel": {
        "dock": "left"
    },
    "collaboration_panel": {
        "dock": "left"
    },
    "git_panel": {
        "dock": "left"
    },
    "icon_theme": "Catppuccin Mocha",
    "vim_mode": true,
    "restore_on_startup": "last_workspace",
    "ui_font_size": 16,
    "buffer_font_size": 14,
    "tab_size": 4,
    "soft_wrap": "editor_width",
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "cursor_blink": false,
    "relative_line_numbers": "enabled",
    "current_line_highlight": "gutter",
    "scrollbar": {
        "show": "never"
    },
    "buffer_line_height": {
        "custom": 1.5
    },
    "gutter": {
        "line_numbers": true
    },
    "vertical_scroll_margin": 3,
    "terminal": {
        "font_family": "JetBrainsMono Nerd Font",
        "font_size": 12,
        "line_height": {
            "custom": 1.5
        },
        "toolbar": {
            "breadcrumbs": false
        }
    },
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "Catppuccin Mocha"
    },
    "auto_install_extensions": {
        "catppuccin": true,
        "catppuccin-icons": true,
        "ruff": true
    },
    "tab_bar": {
        "show": true,
        "show_nav_history_buttons": false,
        "show_tab_bar_buttons": true
    },
    "tabs": {
        "file_icons": true,
        "git_status": true,
        "show_diagnostics": "errors"
    },
    "toolbar": {
        "breadcrumbs": false,
        "quick_actions": false,
        "selections_menu": false,
        "agent_review": false,
        "code_actions": false
    },
    "git": {
        "git_gutter": "tracked_files",
        "inline_blame": {
            "enabled": false
        },
        "hunk_style": "staged_hollow"
    },
    "format_on_save": "off",

    //////////////
    // Language //
    //////////////

    "languages": {
        "Python": {
            "language_servers": ["pyright", "ruff"],
            "format_on_save": "off",
            "formatter": "auto"
        },
        "Zig": {
            "language_servers": ["zls"],
            "format_on_save": "off",
            "formatter": "auto"
        }
    },

    /////////
    // LSP //
    /////////

    "lsp": {
        // python
        "ruff": {
            "initialization_options": {
                "settings": {
                    "lineLength": 79,
                    "lint": {
                        "extendSelect": ["I", "N", "UP", "W", "B", "SIM", "C4"]
                    },
                    "format": {
                        "preview": true
                    },
                    "fixAll": true,
                    "organizeImports": true,
                    "showSyntaxErrors": true
                }
            }
        },
        "pyright": {
            "settings": {
                "python.analysis": {
                    "diagnosticMode": "opensFilesOnly",
                    "typeCheckingMode": "strict"
                }
            }
        },

        // latex
        "texlab": {
            "settings": {
                "texlab": {
                    "build": {
                        "onSave": true
                    }
                }
            }
        },
        "ltex": {
            "settings": {
                "ltex": {
                    "language": ["en-US"]
                }
            }
        }
    },

    /////////
    // SSH //
    /////////

    "ssh_connections": [
        {
            "host": "atlas248",
            "projects": [
                {
                    "paths": ["/dipc/voivodic/Documents/CNF"]
                }
            ]
        },
        {
            "host": "oracle-website"
        }
    ],

    ////////
    // AI //
    ////////

    "edit_predictions": {
        "provider": "zed"
    },
    "language_models": {
        "openai_compatible": {
            "Zai": {
                "api_url": "https://api.z.ai/api/coding/paas/v4",
                "available_models": [
                    {
                        "name": "glm-5.1",
                        "display_name": "GLM-5.1",
                        "max_tokens": 200000,
                        "max_output_tokens": 128000,
                        "capabilities": {
                            "tools": true,
                            "images": false,
                            "parallel_tool_calls": true,
                            "prompt_cache_key": false
                        }
                    },
                    {
                        "name": "glm-5-turbo",
                        "display_name": "GLM-5-Turbo",
                        "max_tokens": 200000,
                        "max_output_tokens": 128000,
                        "capabilities": {
                            "tools": true,
                            "images": false,
                            "parallel_tool_calls": true,
                            "prompt_cache_key": false
                        }
                    },

                    {
                        "name": "glm-4.7",
                        "display_name": "GLM-4.7",
                        "max_tokens": 200000,
                        "max_output_tokens": 128000,
                        "capabilities": {
                            "tools": true,
                            "images": false,
                            "parallel_tool_calls": true,
                            "prompt_cache_key": false
                        }
                    }
                ]
            }
        }
    },

    /////////
    // MCP //
    /////////

    "context_servers": {
        "zai-mcp-server": {
            "enabled": true,
            "command": "npx",
            "args": [
                "-y",
                "@z_ai/mcp-server"
            ],
            "env": {
                "Z_AI_API_KEY": "6cb27c3aef5a43e591265e0bc8d8d7c5.qT4JX5qayBGwkVEB",
                "Z_AI_MODE": "ZAI"
            }
        },
        "web-search-prime": {
            "enabled": true,
            "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
            "headers": {
                "Authorization": "6cb27c3aef5a43e591265e0bc8d8d7c5.qT4JX5qayBGwkVEB"
            }
        },
        "web-reader": {
            "enabled": true,
            "url": "https://api.z.ai/api/mcp/web_reader/mcp",
            "headers": {
                "Authorization": "6cb27c3aef5a43e591265e0bc8d8d7c5.qT4JX5qayBGwkVEB"
            }
        },
        "zread": {
            "enabled": true,
            "url": "https://api.z.ai/api/mcp/zread/mcp",
            "headers": {
                "Authorization": "6cb27c3aef5a43e591265e0bc8d8d7c5.qT4JX5qayBGwkVEB"
            }
        },
        "Context7": {
            "enabled": true,
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp"]
        },
        "sequential-thinking": {
            "enabled": true,
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "tavily": {
            "enabled": true,
            "command": "npx",
            "args": ["-y", "tavily-mcp@latest"]
        }
    },

    ////////////
    // Agents //
    ////////////

    "agent": {
        "sidebar_side": "left",
        "dock": "right",
        "inline_assistant_model": {
            "provider": "google",
            "model": "gemini-3.1-flash-lite"
        },
        "default_model": {
            "enable_thinking": true,
            "provider": "Zai",
            "model": "glm-5.1"
        },
        "default_profile": "write",
        "model_parameters": []
    },
    "agent_servers": {
        "gemini-custom": {
            "type": "custom",
            "command": "gemini"
        }
    }
}
